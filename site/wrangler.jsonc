{
	"compatibility_date": "2026-03-17",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "bolus-website",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"vars": {
		"PUBLIC_SITE_URL": "https://bolusanesthesia.com"
	},
	"observability": {
		"enabled": true
	}
}
