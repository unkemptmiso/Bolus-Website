---
import { getEntry } from "astro:content";
import PageTemplate from "../components/content/PageTemplate.astro";
import {
  getStaticSlug,
  secondaryPages,
  type SitePage,
} from "../config/site-manifest";
import BaseLayout from "../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return secondaryPages.map((page) => ({
    params: { slug: getStaticSlug(page.path) },
    props: { page },
  }));
}

interface Props {
  page: SitePage;
}

const { page } = Astro.props;
const pageSeo = await getEntry("pages", page.id);

if (!pageSeo) {
  throw new Error(`Could not find the '${page.id}' page metadata.`);
}
---

<BaseLayout page={page} seo={pageSeo.data}>
  <PageTemplate page={page} />
</BaseLayout>
