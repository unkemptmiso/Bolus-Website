---
import type { FooterGroupId, SitePage } from "../config/site-manifest";
import type { CollectionEntry } from "astro:content";
import SeoHead from "../components/seo/SeoHead.astro";
import Footer from "../components/site/Footer.astro";
import Header from "../components/site/Header.astro";
import bolusFavicon from "../assets/logos/bolus-favicon.png";
import "../styles/global.css";

interface Props {
  page: SitePage; // Still used for header/labels
  seo: CollectionEntry<"pages">["data"]; // Enforcement of TSOP metadata
  showChrome?: boolean;
  showHeader?: boolean;
  showFooter?: boolean;
  footerOmitGroups?: FooterGroupId[];
  mainClass?: string;
}

const {
  page,
  seo,
  showChrome = true,
  showHeader = showChrome,
  showFooter = showChrome,
  footerOmitGroups = [],
  mainClass = "site-main",
} = Astro.props;
---

<!doctype html>
<html lang="en" data-font-mode="apple">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href={bolusFavicon.src} />
    <SeoHead data={seo} />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    {showHeader && <Header currentPath={page.path} />}
    <main id="content" class={mainClass}>
      <article itemscope itemtype="https://schema.org/Article">
        <slot />
      </article>
    </main>
    {showFooter && <Footer omitGroups={footerOmitGroups} />}
  </body>
</html>
