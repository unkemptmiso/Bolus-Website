---
const securityPoints = [
  "AES-256 encryption",
  "authentication-gated access",
  "PHI stored locally on device",
] as const;
---

<section class="security-section" aria-labelledby="home-security-title">
  <div class="security-section__inner">
    <div class="security-section__copy">
      <h2 id="home-security-title" class="security-section__title">Secure by design.</h2>
      <p class="security-section__body">Bolus is built for secure anesthesia documentation, using AES-256 encryption, authentication-gated access, and local on-device storage so PHI stays off the cloud.</p>
    </div>

    <div class="security-section__points" aria-label="Security proof points">
      {securityPoints.map((point) => (
        <article class="security-point">
          <h3>{point}</h3>
        </article>
      ))}
    </div>

    <a class="security-section__link" href="/security">Full security details</a>
  </div>
</section>
