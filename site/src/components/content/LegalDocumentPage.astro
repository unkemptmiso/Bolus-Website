---
import type { SitePage } from "../../config/site-manifest";
import { legalDocuments } from "../../legal/legal-documents";

interface Props {
  page: SitePage;
}

const { page } = Astro.props;
const document = legalDocuments[page.id];

if (!document) {
  throw new Error(`Missing legal document content for '${page.id}'.`);
}
---

<article class="legal-page">
  <div class="legal-page__inner">
    <header class="legal-page__header">
      <p class="eyebrow">Legal</p>
      <h1 class="legal-page__title">{document.title}</h1>
      <div class="legal-page__meta">
        <p>{document.company}</p>
        <p>Effective Date: {document.effectiveDate}</p>
      </div>
      {document.introduction && (
        <div class="legal-page__intro">
          {document.introduction.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      )}
    </header>

    <div class="legal-page__content">
      {document.sections.map((section) => (
        <section class="legal-page__section" aria-labelledby={section.title}>
          <h2>{section.title}</h2>
          {section.body.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </section>
      ))}
    </div>
  </div>
</article>
