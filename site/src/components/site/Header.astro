---
import { Image } from "astro:assets";

import { getPageById, headerNavigation, siteMetadata } from "../../config/site-manifest";
import bolusMark from "../../assets/logos/bolus-mark.png";
import bolusText from "../../assets/logos/bolus-text.png";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<header class="site-header">
  <div class="nav-pill">
    <a
      class="brand-lockup"
      href="/"
      aria-label="Bolus home"
      style={`--brand-mark-size:${siteMetadata.headerBrand.markSize}px;--brand-wordmark-height:${siteMetadata.headerBrand.wordmarkHeight}px;`}
    >
      <span class="brand-lockup__mark" aria-hidden="true">
        <Image
          src={bolusMark}
          alt="Bolus logo mark"
          widths={[84, 126]}
          sizes={`${siteMetadata.headerBrand.markSize}px`}
        />
      </span>
      <span class="brand-lockup__text" data-scroll-label aria-hidden="true">
        <Image
          src={bolusText}
          alt="Bolus wordmark"
          widths={[187, 280]}
          sizes="124px"
        />
      </span>
    </a>

    <nav class="header-nav" aria-label="Primary">
      <ul class="nav-list">
        {headerNavigation.map((item) => {
          const page = getPageById(item.pageId);

          if (!page) {
            return null;
          }

          const isCurrent = page.path === currentPath;
          return (
            <li>
              <a class:list={["nav-link", { "is-current": isCurrent }]} href={page.path}>
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <a class="header-action" href={siteMetadata.headerCta.href}>
      {siteMetadata.headerCta.label}
    </a>
  </div>
</header>
