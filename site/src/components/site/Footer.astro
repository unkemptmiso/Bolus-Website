---
import { footerNavigation, getPageById, siteMetadata } from "../../config/site-manifest";
---

<footer class="site-footer">
  <div class="footer-grid">
    <div class="footer-brand">
      <p class="eyebrow">Bolus</p>
      <h2>{siteMetadata.tagline}</h2>
      <p>{siteMetadata.description}</p>
    </div>

    {footerNavigation.map((group) => (
      <section>
        <h3>{group.title}</h3>
        <ul class="footer-list">
          {group.links.map((pageId) => {
            const page = getPageById(pageId);

            if (!page) {
              return null;
            }

            return (
              <li>
                <a href={page.path}>{page.navLabel}</a>
              </li>
            );
          })}
        </ul>
      </section>
    ))}
  </div>
</footer>
